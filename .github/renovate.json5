{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended", "helpers:pinGitHubActionDigests"],
  dependencyDashboard: false,
  packageRules: [
    {
      matchUpdateTypes: ["minor", "patch", "pin", "digest"],
      automerge: true,
    },
  ],
  customManagers: [
    {
      customType: "regex",
      description: "Process annotated dependencies in Nix files",
      managerFilePatterns: ["/\\.nix$/"],
      matchStrings: [
        // # renovate: datasource=npm depName=oh-my-opencode
        // "oh-my-opencode@3.11.2"
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( repository=(?<registryUrl>\\S+))?\\n.+@(?<currentValue>\\S+?)\"",
        // # renovate: datasource=github-releases depName=some/dep
        // version = "1.2.3";
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( repository=(?<registryUrl>\\S+))?\\n.+(=\\s+\"|:\\s|=)(&\\S+\\s)?(?<currentValue>[\\w]\\S+?)\"?;",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
    }
  ],
}
