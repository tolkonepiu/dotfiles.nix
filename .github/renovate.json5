{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:best-practices"],
  dependencyDashboard: false,
  lockFileMaintenance: {
    enabled: true,
    commitMessageAction: "flake.lock update",
    schedule: ["* 0-2 * * 1,3,5"],
    recreateWhen: "always",
    rebaseWhen: "behind-base-branch",
  },
  nix: {
    enabled: true,
  },
  packageRules: [
    {
      matchUpdateTypes: ["lockFileMaintenance"],
      rebaseWhen: "behind-base-branch",
      automerge: true,
    },
    {
      matchUpdateTypes: ["minor", "patch", "pin", "digest"],
      automerge: true,
    },
  ],
  customManagers: [
    {
      customType: "regex",
      description: "Process npm package strings in Nix files",
      managerFilePatterns: ["/\\.nix$/"],
      matchStrings: [
        '"(?<depName>@?[-\\w.]+(?:/[-\\w.]+)?)@(?<currentValue>\\d[^"]*)"',
      ],
      datasourceTemplate: "npm",
    },
    {
      customType: "regex",
      description: "Process annotated dependencies in Nix files",
      managerFilePatterns: ["/\\.nix$/"],
      matchStrings: [
        'datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( repository=(?<registryUrl>\\S+))?\\n.+(=\\s+"|:\\s|=)(&\\S+\\s)?(?<currentValue>[\\w]\\S+?)"?;',
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
    },
  ],
}
